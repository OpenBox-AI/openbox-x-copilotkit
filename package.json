{
  "name": "openbox-x-copilotkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:ui": "next dev --turbopack",
    "dev:agent": "node --experimental-strip-types scripts/run-agent.ts",
    "build": "next build --webpack",
    "openbox:admin:setup": "tsx scripts/openbox-setup.ts",
    "openbox:verify": "tsx scripts/openbox-verify.ts",
    "openbox:e2e": "playwright test",
    "start": "next start",
    "lint": "next lint",
    "install:agent": "cd agent && npm install",
    "postinstall": "npm run install:agent"
  },
  "dependencies": {
    "@copilotkit/react-core": "^1.59.3",
    "@copilotkit/runtime": "^1.59.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.7",
    "openbox-sdk": "github:OpenBox-AI/openbox-sdk#38a346d",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "1.3.4",
    "postcss": "8.5.10",
    "uuid": "11.1.1",
    "@langchain/langgraph-checkpoint": "1.0.4",
    "@ag-ui/langgraph": "0.0.36",
    "@ai-sdk/google-vertex": "4.0.142",
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
